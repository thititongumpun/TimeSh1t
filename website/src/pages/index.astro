---
import Base from '../layouts/Base.astro';

const RELEASES_URL = 'https://github.com/thititongumpun/TimeCheese/releases/latest';

let version = 'latest';
let msiUrl = RELEASES_URL;
let exeUrl = RELEASES_URL;
let dmgUrl = RELEASES_URL;

try {
  const res = await fetch('https://api.github.com/repos/thititongumpun/TimeCheese/releases/latest');
  if (res.ok) {
    const release = await res.json();
    version = release.tag_name ?? version;
    const assets: Array<{ name: string; browser_download_url: string }> = release.assets ?? [];
    const msi = assets.find((a) => a.name.endsWith('.msi'));
    const exe = assets.find((a) => a.name.endsWith('-setup.exe') || a.name.endsWith('.exe'));
    const dmg = assets.find((a) => a.name.endsWith('.dmg'));
    if (msi) msiUrl = msi.browser_download_url;
    if (exe) exeUrl = exe.browser_download_url;
    if (dmg) dmgUrl = dmg.browser_download_url;
  }
} catch {
  // offline / rate-limited — fall back to the releases page for every link
}

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const specRows = [
  {
    name: 'Timesheet tracking',
    desc: 'Log entries per project with start/end times, validated against the 09:00–18:00 working window, max 8 worked hours a day (lunch 12:00–13:00 excluded).',
    free: true,
    pro: true,
  },
  {
    name: 'Projects',
    desc: 'Manage active projects and assign entries.',
    free: true,
    pro: true,
  },
  {
    name: 'Archive & AI digests',
    desc: 'Browse archived entries with search; monthly AI summaries.',
    free: true,
    pro: true,
  },
  {
    name: 'Holiday calendar',
    desc: 'Interactive company holiday calendar.',
    free: true,
    pro: true,
  },
  {
    name: 'Msync auto-fill',
    desc: 'Fills your rows into the company Msync/Appsmith site through an SSO-preserving window.',
    free: true,
    pro: true,
  },
  {
    name: 'Park auto-fill',
    desc: 'Carpark registration autofill with vehicle management.',
    free: true,
    pro: true,
  },
  {
    name: 'Missing-day reminders',
    desc: 'A warning banner lists past working days in the current cutoff period with no entry — weekends and company holidays excluded.',
    free: true,
    pro: true,
  },
  {
    name: 'Auto-update',
    desc: 'New versions install themselves.',
    free: true,
    pro: true,
  },
  {
    name: 'Jira Assistant',
    desc: 'Transition Jira issues, “mark done + close Jira” straight from a timesheet row.',
    free: false,
    pro: true,
  },
  {
    name: 'Ask Claude',
    desc: 'Free-form prompts to Claude from inside the app.',
    free: false,
    pro: true,
  },
] as const;
---

<Base title="TimeCheese — desktop timesheet tracker">
  <!-- Hero (Marquee) -->
  <section class="max-w-5xl mx-auto px-6 pt-16 pb-4">
    <h1 class="font-display font-extrabold uppercase tracking-[-0.01em] leading-[1.02] text-[clamp(2.75rem,10vw,7.5rem)]">
      Time<span class="text-[var(--color-accent)]">Cheese</span>
    </h1>
    <p class="mt-5 text-lg text-[var(--color-muted)] max-w-xl">
      A desktop timesheet tracker. Log entries against projects, mark them complete, and never
      miss the monthly cutoff.
    </p>
    <div class="mt-8 flex flex-wrap gap-4">
      <a
        href={msiUrl}
        class="inline-flex items-center justify-center whitespace-nowrap bg-[var(--color-accent)] px-5 py-3 text-sm font-bold uppercase text-[var(--color-on-accent)] shadow-[4px_4px_0_0_var(--color-border)] hover:bg-[var(--color-accent-deep)] transition-colors"
      >
        Download for Windows
      </a>
      <a
        href={dmgUrl}
        class="inline-flex items-center justify-center whitespace-nowrap border-2 border-[var(--color-border)] px-5 py-3 text-sm font-bold uppercase hover:border-[var(--color-accent)] hover:text-[var(--color-accent)] transition-colors"
      >
        Download for macOS
      </a>
    </div>
    <p class="mt-4 text-xs font-mono text-[var(--color-muted)]">
      v{version} · Free for provisioned users · Auto-updates built in
    </p>
    <p class="mt-10 text-xs font-mono text-[var(--color-muted)]">v{version} · home</p>
    <a href={`${base}/home.png`} target="_blank" rel="noopener" class="block cursor-zoom-in">
      <img
        src={`${base}/home.png`}
        alt="TimeCheese Home screen showing the timesheet entries table"
        width="1843"
        height="832"
        loading="eager"
        decoding="async"
        class="mt-2 w-full h-auto border-2 border-[var(--color-border)] shadow-[4px_4px_0_0_var(--color-border)]"
      />
    </a>
  </section>

  <!-- Marquee strip -->
  <div class="marquee mt-12 border-y-2 border-[var(--color-border)] bg-[var(--color-accent)] text-[var(--color-on-accent)]" role="img" aria-label="LOG ONCE — MSYNC AUTO-FILL — PARK AUTO-FILL — 09:00–18:00 VALIDATED — NEVER MISS THE CUTOFF">
    <div class="marquee-track py-2.5 text-sm font-bold uppercase tracking-[0.04em]" aria-hidden="true">
      <span class="shrink-0 whitespace-nowrap">LOG ONCE ✱ MSYNC AUTO-FILL ✱ PARK AUTO-FILL ✱ 09:00–18:00 VALIDATED ✱ NEVER MISS THE CUTOFF ✱&nbsp;</span>
      <span class="shrink-0 whitespace-nowrap">LOG ONCE ✱ MSYNC AUTO-FILL ✱ PARK AUTO-FILL ✱ 09:00–18:00 VALIDATED ✱ NEVER MISS THE CUTOFF ✱&nbsp;</span>
    </div>
  </div>

  <!-- Day-timeline band -->
  <section class="max-w-5xl mx-auto px-6 py-20 grid md:grid-cols-2 gap-12 items-center">
    <div>
      <h2 class="font-display font-extrabold uppercase tracking-[-0.01em] leading-[1.02] text-3xl">
        <span class="text-[var(--color-accent)]">◆</span> Your day, one bar.
      </h2>
      <p class="mt-3 text-[var(--color-muted)]">
        Entries validate against the 09:00–18:00 window — max 8 worked hours, lunch never counted.
      </p>
    </div>

    <!-- Signature "day timeline" graphic -->
    <div class="border-2 border-[var(--color-border)] bg-[var(--color-surface)] p-6 shadow-[4px_4px_0_0_var(--color-border)]">
      <div class="flex items-center justify-between mb-4">
        <span class="text-xs font-mono text-[var(--color-muted)]">today’s timeline</span>
        <span class="inline-flex items-center rounded-full border border-[var(--color-accent)]/40 bg-[var(--color-accent)]/10 px-2.5 py-1 text-xs font-mono text-[var(--color-accent)]">
          7.5h / 8h
        </span>
      </div>
      <div aria-hidden="true" class="relative h-14 rounded-md bg-[var(--color-bg)] border border-[var(--color-border)] overflow-hidden flex">
        <!-- 09:00-11:30 API review (2.5h of 9h = 27.8%) -->
        <div class="timeline-block h-full bg-[var(--color-accent)]/80 flex items-center justify-center text-[10px] font-mono text-[var(--color-on-accent)]" style="width: 27.8%;">
          API review
        </div>
        <!-- 11:30-12:00 gap -->
        <div class="h-full" style="width: 5.6%;"></div>
        <!-- 12:00-13:00 lunch, hatched -->
        <div
          class="h-full flex items-center justify-center text-[9px] font-mono text-[var(--color-muted)]"
          style="width: 11.1%; background-image: repeating-linear-gradient(45deg, var(--color-border) 0, var(--color-border) 3px, transparent 3px, transparent 7px);"
          title="lunch — never counted"
        >
          lunch
        </div>
        <!-- 13:00-18:00 MED-142 (5h of 9h = 55.5%) -->
        <div class="timeline-block h-full bg-[var(--color-accent)]/80 flex items-center justify-center text-[10px] font-mono text-[var(--color-on-accent)]" style="width: 55.5%; animation-delay: 0.25s;">
          MED-142
        </div>
      </div>
      <div aria-hidden="true" class="relative mt-2 h-4 text-[10px] font-mono text-[var(--color-muted)]">
        <span class="absolute left-0">09:00</span>
        <span class="absolute left-[33.3%] -translate-x-1/2">12:00</span>
        <span class="absolute left-[44.4%]">13:00</span>
        <span class="absolute right-0">18:00</span>
      </div>
      <p class="mt-4 text-xs text-[var(--color-muted)]">
        12:00–13:00 lunch is hatched and dimmed — it’s never counted toward the 8-hour cap.
      </p>
    </div>
  </section>

  <div class="max-w-5xl mx-auto px-6 py-2 text-center text-[var(--color-accent-deep)] text-lg" aria-hidden="true">✱ ✱ ✱ ✱</div>

  <!-- Auto-fill diptych -->
  <section class="py-16">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="font-display font-extrabold uppercase tracking-[-0.01em] leading-[1.02] text-3xl">
        <span class="text-[var(--color-accent-deep)]">◆</span> Filed for you. Twice.
      </h2>
      <p class="mt-2 text-[var(--color-muted)]">
        Log your day once — TimeCheese files it into the company systems for you.
      </p>

      <!-- Row 1: text above, full-width proof shot -->
      <div class="mt-16">
        <h3 class="font-display text-xl font-bold">Msync auto-fill</h3>
        <p class="mt-3 text-[var(--color-muted)] max-w-xl">
          Opens the company Msync site in an SSO-preserving window and fills your timesheet
          rows into the embedded Appsmith form — no retyping, no lost session.
        </p>
        <div class="mt-6 border-2 border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-[4px_4px_0_0_var(--color-accent-deep)]">
          <a href={`${base}/msync.png`} target="_blank" rel="noopener" class="block cursor-zoom-in">
            <img
              src={`${base}/msync.png`}
              alt="Timesheets table with five rows multi-selected and a Mark done / Send to Msync action bar"
              width="1843"
              height="832"
              loading="lazy"
              decoding="async"
              class="w-full h-auto"
            />
          </a>
          <p class="mt-3 text-[10px] font-mono text-[var(--color-muted)]">5 rows selected — one click to Msync · click to view full size</p>
        </div>
      </div>

      <!-- Row 2: proof left / text right (reversed on md+) -->
      <div class="mt-16 grid md:grid-cols-2 gap-12 items-center">
        <div class="md:order-2">
          <h3 class="font-display text-xl font-bold">Park auto-fill</h3>
          <p class="mt-3 text-[var(--color-muted)]">
            Carpark registration filled the same way — pick a vehicle, TimeCheese completes the
            form in the SSO window.
          </p>
        </div>
        <div class="md:order-1 border-2 border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-[4px_4px_0_0_var(--color-accent-deep)]">
          <span class="font-mono text-xs text-[var(--color-muted)]">park · today</span>
          <div class="mt-3">
            <div class="flex items-center justify-between border-b border-[var(--color-border)] py-2 text-xs font-mono last:border-b-0">
              <span class="text-[var(--color-muted)]">plate กข 1234 · registered <span class="text-[var(--color-accent-deep)]">✓</span></span>
            </div>
          </div>
          <p class="mt-3 text-[10px] font-mono text-[var(--color-muted)]">vehicles managed in the Park tab</p>
        </div>
      </div>
    </div>
  </section>

  <!-- And the rest -->
  <section class="border-t-2 border-[var(--color-border)] py-16">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="font-display font-extrabold uppercase tracking-[-0.01em] leading-[1.02] text-3xl">
        <span class="text-[var(--color-accent)]">◆</span> And the rest.
      </h2>
      <div class="mt-8 grid md:grid-cols-2 gap-8">
        <div class="border-2 border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-[4px_4px_0_0_var(--color-border)]">
          <a href={`${base}/holiday.png`} target="_blank" rel="noopener" class="block cursor-zoom-in">
            <img
              src={`${base}/holiday.png`}
              alt="Holiday page showing the July 2026 calendar and Thai holiday list"
              width="1843"
              height="832"
              loading="lazy"
              decoding="async"
              class="w-full h-auto"
            />
          </a>
          <p class="mt-3 text-[10px] font-mono text-[var(--color-muted)]">holiday calendar · click to view full size</p>
        </div>
        <div class="border-2 border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-[4px_4px_0_0_var(--color-border)]">
          <a href={`${base}/jira.png`} target="_blank" rel="noopener" class="block cursor-zoom-in">
            <img
              src={`${base}/jira.png`}
              alt="Jira Assistant page with prompt box and Jira connected badge"
              width="1843"
              height="832"
              loading="lazy"
              decoding="async"
              class="w-full h-auto"
            />
          </a>
          <p class="mt-3 text-[10px] font-mono text-[var(--color-muted)]">jira assistant · click to view full size</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Spec sheet -->
  <section class="py-20">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="font-display font-extrabold uppercase tracking-[-0.01em] leading-[1.02] text-3xl">
        <span class="text-[var(--color-accent)]">◆</span> Everything in the box.
      </h2>
      <p class="mt-2 text-[var(--color-muted)] max-w-2xl">
        All of it free for provisioned users. The two Pro rows aren’t a paid tier — they ride
        your own Claude Code subscription and the Atlassian MCP server.
      </p>

      <div class="mt-8 overflow-x-auto">
        <table class="w-full text-sm min-w-[560px]">
          <thead>
            <tr class="border-b-2 border-[var(--color-border)]">
              <th class="text-left py-3 font-semibold">Feature</th>
              <th class="text-center py-3 font-semibold w-20">Free</th>
              <th class="text-center py-3 font-semibold w-20">Pro</th>
            </tr>
          </thead>
          <tbody>
            {specRows.map((row) => (
              <tr class="border-b-2 border-[var(--color-border)]">
                <td class="py-3 pr-4">
                  <span class="font-semibold">{row.name}</span>
                  <span class="block text-[var(--color-muted)] text-xs mt-0.5">{row.desc}</span>
                </td>
                <td class:list={['py-3 text-center', row.free ? 'text-[var(--color-accent)]' : 'text-[var(--color-muted)]']}>{row.free ? '✓' : '—'}</td>
                <td class:list={['py-3 text-center', row.pro ? 'text-[var(--color-accent)]' : 'text-[var(--color-muted)]']}>{row.pro ? '✓' : '—'}</td>
              </tr>
            ))}
            <tr>
              <td class="py-3 pr-4">
                <span class="font-semibold">Non-project Msync auto-fill</span>
                <span class="block text-[var(--color-muted)] text-xs mt-0.5">LEAVE, meetings, and other non-project rows filled the same way.</span>
              </td>
              <td class="py-3 text-center font-mono text-[10px] text-[var(--color-muted)]">planned</td>
              <td class="py-3 text-center font-mono text-[10px] text-[var(--color-muted)]">planned</td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class="text-xs text-[var(--color-muted)] mt-3">
        Pro rows require a locally installed Claude Code CLI (your own subscription) plus the Atlassian MCP server.
      </p>
    </div>
  </section>

  <!-- Quickstart -->
  <section class="py-16">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="font-display font-extrabold uppercase tracking-[-0.01em] leading-[1.02] text-3xl">
        <span class="text-[var(--color-accent-deep)]">◆</span> Quickstart.
      </h2>
      <ol class="mt-8 max-w-2xl">
        <li class="flex gap-5 border-l-2 border-[var(--color-border)] pl-6 pb-8 last:pb-0">
          <span class="font-mono text-sm text-[var(--color-accent)]">01</span>
          <div>
            <h3 class="font-semibold">Install</h3>
            <p class="text-sm text-[var(--color-muted)]">Run the .msi on Windows or drag to Applications on macOS.</p>
          </div>
        </li>
        <li class="flex gap-5 border-l-2 border-[var(--color-border)] pl-6 pb-8 last:pb-0">
          <span class="font-mono text-sm text-[var(--color-accent)]">02</span>
          <div>
            <h3 class="font-semibold">Sign in</h3>
            <p class="text-sm text-[var(--color-muted)]">Use the email + password your admin provisioned.</p>
          </div>
        </li>
        <li class="flex gap-5 border-l-2 border-[var(--color-border)] pl-6 pb-8 last:pb-0">
          <span class="font-mono text-sm text-[var(--color-accent)]">03</span>
          <div>
            <h3 class="font-semibold">Log your first entry</h3>
            <p class="text-sm text-[var(--color-muted)]">Pick a project, date, and time — TimeCheese validates it for you.</p>
          </div>
        </li>
      </ol>
      <p class="mt-2 text-sm">
        <a href={`${base}/docs/quickstart/`} class="text-[var(--color-accent)] hover:text-[var(--color-accent-deep)] font-semibold">Full quickstart guide →</a>
      </p>
    </div>
  </section>

  <div class="max-w-5xl mx-auto px-6 py-2 text-center text-[var(--color-accent-deep)] text-lg" aria-hidden="true">✱ ✱ ✱ ✱</div>

  <!-- Download -->
  <section id="download" class="py-20">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="font-display font-extrabold uppercase tracking-[-0.01em] leading-[1.02] text-3xl">
        <span class="text-[var(--color-accent)]">◆</span> Download.
      </h2>
      <div class="mt-8 grid sm:grid-cols-2 gap-8">
        <div class="border-2 border-[var(--color-border)] bg-[var(--color-surface)] p-6 shadow-[4px_4px_0_0_var(--color-border)]">
          <h3 class="font-semibold">Windows</h3>
          <p class="mt-1.5 text-sm text-[var(--color-muted)]">.msi installer or .exe setup.</p>
          <div class="mt-4 flex flex-wrap gap-3">
            <a href={msiUrl} class="text-sm font-semibold text-[var(--color-accent)] hover:text-[var(--color-accent-deep)]">.msi ↓</a>
            <a href={exeUrl} class="text-sm font-semibold text-[var(--color-accent)] hover:text-[var(--color-accent-deep)]">.exe ↓</a>
          </div>
        </div>
        <div class="border-2 border-[var(--color-border)] bg-[var(--color-surface)] p-6 shadow-[4px_4px_0_0_var(--color-border)]">
          <h3 class="font-semibold">macOS</h3>
          <p class="mt-1.5 text-sm text-[var(--color-muted)]">Universal .dmg — Apple Silicon + Intel.</p>
          <div class="mt-4 flex flex-wrap gap-3">
            <a href={dmgUrl} class="text-sm font-semibold text-[var(--color-accent)] hover:text-[var(--color-accent-deep)]">.dmg ↓</a>
          </div>
        </div>
      </div>
      <p class="mt-6 text-sm">
        <a href={RELEASES_URL} class="text-[var(--color-accent)] hover:text-[var(--color-accent-deep)] font-semibold">All versions →</a>
      </p>

      <p class="mt-10 text-[var(--color-muted)]">
        No sign-up — accounts are provisioned by your admin.
        <a href={`${base}/docs/getting-access/`} class="text-[var(--color-accent)] hover:text-[var(--color-accent-deep)] font-semibold">Getting access →</a>
      </p>
    </div>
  </section>
</Base>
