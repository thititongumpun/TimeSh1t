---
import { marked } from 'marked';
import Base from '../layouts/Base.astro';

// website/src/pages/changelog.astro -> repo root CHANGELOG.md, inlined at build time
import raw from '../../../CHANGELOG.md?raw';

// Split on "## [" headings; skip the top-level "# Changelog" preamble.
const sections = raw.split(/\n(?=## \[)/).slice(1);

const versions = sections.map((section) => {
  const headingMatch = section.match(/^## \[([^\]]+)\]\s*-\s*(.+)$/m);
  const version = headingMatch?.[1] ?? 'unknown';
  const date = headingMatch?.[2]?.trim() ?? '';
  const body = section.replace(/^## \[[^\]]+\]\s*-\s*.+$/m, '').trim();
  return { version, date, html: marked.parse(body) as string };
});
---

<Base title="Changelog · TimeCheese" description="Version history for TimeCheese.">
  <section class="max-w-3xl mx-auto px-6 py-16">
    <h1 class="font-display text-4xl font-bold tracking-tight">Changelog</h1>
    <p class="mt-2 text-[var(--color-muted)]">Every notable change, newest first.</p>

    <div class="mt-10 flex flex-col gap-6">
      {versions.map((v) => (
        <article class="rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] p-6">
          <header class="flex items-baseline gap-3">
            <h2 class="font-display text-xl font-bold text-[var(--color-accent)]">{v.version}</h2>
            <span class="text-xs font-mono text-[var(--color-muted)]">{v.date}</span>
          </header>
          <div class="changelog-body mt-3 text-sm" set:html={v.html} />
        </article>
      ))}
    </div>
  </section>
</Base>
