---
import '@fontsource-variable/bricolage-grotesque';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'TimeCheese — a desktop timesheet tracker.' } = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const nav = [
  { href: `${base}/`, label: 'Home' },
  { href: `${base}/changelog/`, label: 'Changelog' },
  { href: `${base}/docs/quickstart/`, label: 'Quickstart' },
  { href: `${base}/docs/getting-access/`, label: 'Getting access' },
];

const currentPath = Astro.url.pathname.replace(/\/$/, '');
const isActive = (href: string) => currentPath === href.replace(/\/$/, '');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <meta name="description" content={description} />
    <title>{title}</title>
    <script is:inline>
      (function () {
        var stored = localStorage.getItem('theme');
        var theme = stored || (matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark');
        document.documentElement.dataset.theme = theme;
      })();
    </script>
  </head>
  <body class="min-h-screen flex flex-col">
    <header class="border-b-2 border-[var(--color-border)]">
      <nav class="max-w-5xl mx-auto grid grid-cols-[1fr_auto_1fr] items-center h-16 px-6">
        <a
          href={`${base}/`}
          class="justify-self-start font-display text-lg font-bold tracking-tight text-[var(--color-text)] hover:text-[var(--color-accent)]"
        >
          🧀 TimeCheese
        </a>
        <ul class="hidden md:flex justify-self-center gap-6 text-sm">
          {nav.slice(1).map((item) => (
            <li>
              <a
                href={item.href}
                aria-current={isActive(item.href) ? 'page' : undefined}
                class:list={[
                  'whitespace-nowrap transition-colors',
                  isActive(item.href)
                    ? 'text-[var(--color-accent)] underline underline-offset-4 decoration-2'
                    : 'text-[var(--color-muted)] hover:text-[var(--color-accent)]',
                ]}
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
        <div class="justify-self-end flex items-center gap-3">
          <button
            id="theme-toggle"
            type="button"
            aria-label="Toggle theme"
            class="cursor-pointer text-[var(--color-muted)] hover:text-[var(--color-accent)] transition-colors"
          >
            <span class="theme-icon-dark">☀</span>
            <span class="theme-icon-light">☾</span>
          </button>
          <a
            href={`${base}/#download`}
            class="inline-flex min-h-11 items-center whitespace-nowrap uppercase rounded-md bg-[var(--color-accent)] px-3.5 py-2 text-sm font-semibold text-[var(--color-on-accent)] shadow-[3px_3px_0_0_var(--color-border)] hover:bg-[var(--color-accent-deep)] transition-colors"
          >
            Download
          </a>
        </div>
      </nav>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="border-t-2 border-[var(--color-border)] mt-16">
      <div class="max-w-5xl mx-auto px-6 py-10 flex justify-end gap-4 text-sm text-[var(--color-muted)]">
        <ul class="flex flex-wrap gap-6">
          <li><a href="https://github.com/thititongumpun/TimeCheese" class="hover:text-[var(--color-accent)]">GitHub</a></li>
          <li><a href={`${base}/changelog/`} class="hover:text-[var(--color-accent)]">Changelog</a></li>
          <li><a href={`${base}/docs/quickstart/`} class="hover:text-[var(--color-accent)]">Quickstart</a></li>
          <li><a href={`${base}/docs/getting-access/`} class="hover:text-[var(--color-accent)]">Getting access</a></li>
        </ul>
      </div>
    </footer>

    <dialog id="lightbox" class="lightbox">
      <img id="lightbox-img" src="" alt="" />
    </dialog>

    <script is:inline>
      (function () {
        var btn = document.getElementById('theme-toggle');
        btn.addEventListener('click', function () {
          var next = document.documentElement.dataset.theme === 'light' ? 'dark' : 'light';
          document.documentElement.dataset.theme = next;
          localStorage.setItem('theme', next);
        });
      })();
    </script>
    <script is:inline>
      (function () {
        var dialog = document.getElementById('lightbox');
        var img = document.getElementById('lightbox-img');
        document.querySelectorAll('main a.shot').forEach(function (link) {
          link.addEventListener('click', function (e) {
            var thumb = link.querySelector('img');
            if (!thumb) return;
            e.preventDefault();
            img.src = link.href;
            img.alt = thumb.alt;
            dialog.showModal();
          });
        });
        dialog.addEventListener('click', function () {
          dialog.close();
        });
        dialog.addEventListener('close', function () {
          img.src = '';
          img.alt = '';
        });
      })();
    </script>
  </body>
</html>
