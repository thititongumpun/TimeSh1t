---
import '@fontsource-variable/bricolage-grotesque';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'TimeCheese — a desktop timesheet tracker.' } = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const nav = [
  { href: `${base}/`, label: 'Home' },
  { href: `${base}/changelog/`, label: 'Changelog' },
  { href: `${base}/docs/quickstart/`, label: 'Quickstart' },
  { href: `${base}/docs/getting-access/`, label: 'Getting access' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <meta name="description" content={description} />
    <title>{title}</title>
    <script is:inline>
      (function () {
        var stored = localStorage.getItem('theme');
        var theme = stored || (matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark');
        document.documentElement.dataset.theme = theme;
      })();
    </script>
  </head>
  <body class="min-h-screen flex flex-col overflow-x-hidden">
    <header class="border-b border-[var(--color-border)]">
      <nav class="max-w-5xl mx-auto flex items-center justify-between px-6 py-4">
        <a href={`${base}/`} class="font-display text-lg font-bold tracking-tight text-[var(--color-text)] hover:text-[var(--color-accent)]">
          🧀 TimeCheese
        </a>
        <ul class="flex items-center gap-6 text-sm text-[var(--color-muted)]">
          {nav.slice(1).map((item) => (
            <li>
              <a href={item.href} class="hover:text-[var(--color-accent)] transition-colors">{item.label}</a>
            </li>
          ))}
        </ul>
        <button
          id="theme-toggle"
          type="button"
          aria-label="Toggle theme"
          class="cursor-pointer text-[var(--color-muted)] hover:text-[var(--color-accent)] transition-colors"
        >
          <span class="theme-icon-dark">☀</span>
          <span class="theme-icon-light">☾</span>
        </button>
      </nav>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="border-t border-[var(--color-border)] mt-16">
      <div class="max-w-5xl mx-auto px-6 py-10 flex justify-end gap-4 text-sm text-[var(--color-muted)]">
        <ul class="flex flex-wrap gap-6">
          <li><a href="https://github.com/thititongumpun/TimeCheese" class="hover:text-[var(--color-accent)]">GitHub</a></li>
          <li><a href={`${base}/changelog/`} class="hover:text-[var(--color-accent)]">Changelog</a></li>
          <li><a href={`${base}/docs/quickstart/`} class="hover:text-[var(--color-accent)]">Quickstart</a></li>
          <li><a href={`${base}/docs/getting-access/`} class="hover:text-[var(--color-accent)]">Getting access</a></li>
        </ul>
      </div>
    </footer>
    <script is:inline>
      (function () {
        var btn = document.getElementById('theme-toggle');
        btn.addEventListener('click', function () {
          var next = document.documentElement.dataset.theme === 'light' ? 'dark' : 'light';
          document.documentElement.dataset.theme = next;
          localStorage.setItem('theme', next);
        });
      })();
    </script>
  </body>
</html>
